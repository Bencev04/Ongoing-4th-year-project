# =============================================================================
# Git Ignore
# =============================================================================

# Python bytecode & caches
__pycache__/
*.pyc
*.pyo
*.pyd
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Test / coverage artifacts
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.pytest_cache/

# IDE / editor files
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Environment variables (secrets!)
.env
.env.local
.env.production

# Docker overrides (local dev only)
docker-compose.override.yml

# SonarQube scanner working directory
.scannerwork/

# Trivy cache
.trivy-cache/

# Build artifacts
dist/
build/
*.egg-info/

# Logs
*.log

# Database files (local dev)
*.sqlite3
*.db
