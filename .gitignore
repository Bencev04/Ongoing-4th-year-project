# Public mirror safety ignores

# Environment files / local secrets
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets.yaml
kubeconfig
kubeconfig-*

# Terraform local/generated files
*.tfstate
*.tfstate.*
*.tfplan
*.tfvars
*.tfvars.json
.terraform/
.terraform.lock.hcl
crash.log
crash.*.log

# Python/generated files
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# Tool caches
.ruff_cache/
.mypy_cache/
.trivy-cache/
.scannerwork/

# OS/editor files
.DS_Store
Thumbs.db
.vscode/
.idea/
