# =============================================================================
# .gitignore — Files that should NEVER be committed to Git
# =============================================================================

# --- Terraform ---------------------------------------------------------------
# These files contain sensitive data or are generated by Terraform.
# They should never be in version control.

# Local state files (we use S3 remote state instead)
*.tfstate
*.tfstate.*

# Binary plan files (generated by terraform plan -out)
*.tfplan

# Downloaded providers and modules (like node_modules)
.terraform/

# Provider lock file (regenerated by terraform init)
.terraform.lock.hcl

# Terraform crash dumps and local overrides
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# JSON variable files (we use .tfvars instead)
*.tfvars.json

# --- Secrets — NEVER commit these! -------------------------------------------
# SSL/TLS certificates, private keys, and secrets directories
*.pem
*.key
secrets/

# --- OS generated files ------------------------------------------------------
# OS metadata
.DS_Store
Thumbs.db

# --- Python -------------------------------------------------------------------
# Python bytecode cache
__pycache__/

# --- IDE / Editor files ------------------------------------------------------
# IDE/editor settings
.vscode/
.idea/
