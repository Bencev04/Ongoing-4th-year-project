# CRM Calendar Environment Configuration
# Copy this file to .env and customize values

# Database Configuration
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=crm_password
POSTGRES_DB=crm_calendar

# Service URLs (for Docker networking)
DATABASE_URL=postgresql+asyncpg://crm_user:crm_password@db:5432/crm_calendar

# Security — CHANGE THESE BEFORE DEPLOYING TO STAGING/PRODUCTION
SECRET_KEY=your-super-secret-key-change-this-in-production
REDIS_PASSWORD=redis-dev-password
DEBUG=false

# Observability
LOG_LEVEL=INFO
ENVIRONMENT=development
SERVICE_VERSION=local

# Google Maps API Keys
GOOGLE_MAPS_BROWSER_KEY=
GOOGLE_MAPS_SERVER_KEY=

# Host Ports (published to your machine)
CRM_HTTP_PORT=8088
CRM_POSTGRES_PORT=5433

# Internal Service Ports (Docker network)
USER_SERVICE_PORT=8001
CUSTOMER_SERVICE_PORT=8002
JOB_SERVICE_PORT=8003
FRONTEND_PORT=8000
